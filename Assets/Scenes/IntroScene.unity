--- !u!114 &837145994
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 837145991}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2b5158ffa716f0c4d9c1506045ec9324, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::IntroCutsceneManager
  introScenes:
  - backgroundImage: {fileID: -699148430, guid: cbef3b8a8cec2d44694947cb34be2576, type: 3}
    dialogueText: "S\xE0i G\xF2n, 6 gi\u1EDD s\xE1ng. Khi th\xE0nh ph\u1ED1 c\xF2n
      ch\u01B0a th\u1EE9c gi\u1EA5c, nh\u1EEFng con ph\u1ED1 v\u1EABn y\xEAn t\u0129nh,
      v\xE0 m\u1ED9t ng\xE0y m\u1EDBi \u0111ang d\u1EA7n b\u1EAFt \u0111\u1EA7u"
    voiceLine: {fileID: 8300000, guid: 4b8d5f2770c096d4aa7b916eb0dbe472, type: 3}
  - backgroundImage: {fileID: -1299263133, guid: 30f44bd7a8eea4b4fb5f64b036eedadd, type: 3}
    dialogueText: "Gi\u1EEFa d\xF2ng \u0111\u1EDDi v\u1ED9i v\xE3, c\xF3 m\u1ED9t
      ng\u01B0\u1EDDi mang trong m\xECnh m\u1ED9t \u01B0\u1EDBc m\u01A1 gi\u1EA3n
      d\u1ECB, \u0111\u01B0\u1EE3c t\u1EF1 tay x\xE2y d\u1EF1ng m\u1ED9t \u0111i\u1EC1u
      g\xEC \u0111\xF3 cho ri\xEAng m\xECnh"
    voiceLine: {fileID: 8300000, guid: 7885253042c44634b89b3d5f0ca1a954, type: 3}
  - backgroundImage: {fileID: 741440375, guid: 0791d44b7d64c1046b3c175b27491c47, type: 3}
    dialogueText: "Cu\u1ED9c s\u1ED1ng ch\u01B0a bao gi\u1EDD l\xE0 d\u1EC5 d\xE0ng.
      Nh\u1EEFng b\u1EEFa c\u01A1m \u0111\u1EA1m b\u1EA1c, nh\u1EEFng ng\xE0y th\xE1ng
      ch\u1EADt v\u1EADt, nh\u01B0ng c\u0169ng ch\xEDnh t\u1EEB \u0111\xF3, anh hi\u1EC3u
      \u0111\u01B0\u1EE3c gi\xE1 tr\u1ECB c\u1EE7a t\u1EEBng h\u1EA1t g\u1EA1o, v\xE0
      l\xFD do \u0111\u1EC3 kh\xF4ng bao gi\u1EDD b\u1ECF cu\u1ED9c"
    voiceLine: {fileID: 8300000, guid: 9fe591ce505347c4c9dfac92421bcfbc, type: 3}
  - backgroundImage: {fileID: -1683951251, guid: 32e5ed3854939a64d8cff247307c57b2, type: 3}
    dialogueText: "M\u1ED9t b\u1EBFp than nh\u1ECF \u0111\u01B0\u1EE3c nh\xF3m l\xEAn,
      m\u1ED9t qu\xE1n \u0103n nh\u1ECF \u0111\u01B0\u1EE3c d\u1EF1ng n\xEAn. Kh\xF4ng
      ph\u1EA3i \u0111\u1EC3 thay \u0111\u1ED5i th\u1EBF gi\u1EDBi, m\xE0 \u0111\u1EC3
      thay \u0111\u1ED5i ch\xEDnh cu\u1ED9c \u0111\u1EDDi m\xECnh. V\xE0 t\u1EEB
      h\xF4m nay, h\xE0nh tr\xECnh \u1EA5y ch\xEDnh th\u1EE9c b\u1EAFt \u0111\u1EA7u"
    voiceLine: {fileID: 8300000, guid: da2bea687f2da1e4ab2ff4f1fa3cf227, type: 3}
  nextSceneName: GameScene
  backgroundImageUI: {fileID: 1933973445}
  dialogueTextUI: {fileID: 2141532870}
  audioSource: {fileID: 335473127}
  typeWriterSpeed: 0.05
